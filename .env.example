# ─────────────────────────────────────────────────────────────────────────────
# Hello-EQ — environment variables
#
# Copy this file to `.env` and fill in the values. Vars prefixed with `VITE_`
# are inlined into the client bundle by Vite (visible in the browser) — never
# put server-only secrets behind that prefix. All other vars are only read by
# the Vercel serverless functions under `api/`.
#
# Quick reference — what each surface needs to run end-to-end:
#   🧠 Career EQ Coach     → ANTHROPIC_API_KEY (+ VITE_SUPABASE_* if signed in)
#   🧪 Product Career      → ANTHROPIC_API_KEY, ANTHROPIC_EVALUATOR_API_KEY
#   ✨ Idea Validator      → ANTHROPIC_API_KEY, VITE_SUPABASE_*,
#                            SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY
#   🌐 Public profile page → SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY
# ─────────────────────────────────────────────────────────────────────────────


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║ CLIENT (browser-exposed — VITE_ prefix)                                   ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# ── Supabase — auth + Validator session persistence ──────────────────────────
# Used by `src/lib/supabaseClient.ts` for the browser-side Supabase client
# (auth, Validator sessions/messages/outcomes with RLS).
# Find these at: Supabase Dashboard → Project Settings → API.
# If absent: sign-in is disabled and Validator sessions can't be persisted.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-public-key>

# ── HEQ Club signup webhook (optional) ───────────────────────────────────────
# Used by `src/components/common/AiGateModal.tsx`. When set, the AI-gate
# signup form POSTs `{name, email, timestamp}` to this URL in addition to
# saving locally. Point it at a Google Apps Script, Formspree, Airtable
# webhook, etc. If absent: signups still save to localStorage; no POST.
VITE_SIGNUP_WEBHOOK_URL=


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║ SERVER (Vercel functions only — never exposed to the browser)             ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# ── Anthropic — shared Claude API key ────────────────────────────────────────
# Powers every chat/generation endpoint:
#   • /api/claude           — Career EQ Coach routing, journaling follow-ups,
#                             Decision Log brief, PM Assist artifacts, LinkedIn
#                             post generator, Product Taste legacy fallback
#   • /api/validator        — Idea Validator chat + Build Prompt generation
#   • /api/evaluate-taste   — falls back to this key if the evaluator key below
#                             is not set
# If absent: every AI-backed feature returns 500.
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Anthropic — Product Taste V1 Evaluator key (optional but recommended) ────
# Used ONLY by /api/evaluate-taste so evaluator traffic can be metered and
# disabled independently from the rest of the AI surface.
# If absent: the endpoint returns 503 and the Product Taste UI automatically
# falls back to the legacy free-text analysis path — taste exercises still
# complete, but you lose the per-question scores, verdict, strengths/
# weaknesses, and coaching output.
ANTHROPIC_EVALUATOR_API_KEY=sk-ant-api03-...

# ── Supabase — service-role credentials (server-only) ────────────────────────
# Used by /api/public-profile/[slug] to read aggregated, non-PII credibility
# data for the public `/p/:slug` profile page. SUPABASE_URL is the same
# project URL as VITE_SUPABASE_URL above, but kept separate so the server
# function can run without depending on the Vite-prefixed copy.
#
# SUPABASE_SERVICE_ROLE_KEY is privileged — it bypasses RLS. Treat it like a
# password: never commit, never expose to the browser, never log.
# Find it at: Supabase Dashboard → Project Settings → API → service_role key.
#
# If either is absent: /api/public-profile/[slug] returns 503 and shared
# `/p/:slug` profile links won't resolve.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-secret-key>
