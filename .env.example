# ── Supabase — database + auth ────────────────────────────────────────────────
# Get these from your Supabase project Settings → API
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-public-key>

# ── Shared AI key — used by all existing AI features (/api/claude) ────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Evaluator key — used ONLY by /api/evaluate-taste (Product Taste V1) ───────
# This is a SEPARATE key so evaluator traffic can be monitored and disabled
# independently. If this key is absent the evaluator returns 503 and the UI
# falls back to the basic analysis path automatically.
ANTHROPIC_EVALUATOR_API_KEY=sk-ant-api03-...

# ── PM Graph integration — /api/pm-graph/evaluate-friction-case ───────────────
# PM_GRAPH_BASE_URL: Base URL of the PM Graph evaluation service (no trailing slash).
#   The adapter appends /evaluate to this URL for server-to-server calls.
#   Example: https://api.pm-graph.internal
PM_GRAPH_BASE_URL= https://<pm-graph-base-url>


# PM_GRAPH_SERVICE_TOKEN: Bearer token used to authenticate server-to-server
#   requests to PM Graph. Never expose this in client-side code.
#   If either variable is absent the endpoint returns a degraded response
#   (degraded: true, reason: 'pm_graph_unavailable') — the UI must handle this.
PM_GRAPH_SERVICE_TOKEN=<your-pm-graph-service-token>
